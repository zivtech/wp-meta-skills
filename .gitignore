# Local/editor state
.DS_Store
.idea/
.vscode/
.claude/settings.local.json

# Local-only session notes and plans (may contain machine-local paths; the
# committed handoff convention is docs/wordpress/goal-handoff-*.md)
/HANDOFF-*.md
/plans/

# Python caches and test state
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# JavaScript package installs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local runtime/output scratch space
.omc/
tmp/
dist/
build/

# Evaluation run artifacts (regenerated by the harness; never tracked)
evals/results/

# Composer-fetched PHP analysis toolchain (pinned by composer.lock; the vendor
# tree includes GPL-3.0 wp-hooks data that must never be committed to this
# Apache-2.0 repository)
evals/harness/php-tools/vendor/
